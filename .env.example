# Environment variables for deployment
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

GOOGLE_API_KEY=your-google-api-key-here

# ── Shared / required ─────────────────────────────────────────────────────────

# Meta webhook verify token (shared across all phone numbers)
WHATSAPP_VERIFY_TOKEN=your-verify-token-here

# Meta app secret (required in production for HMAC webhook signature validation)
WHATSAPP_APP_SECRET=your-app-secret-here

# Backend API
BACKEND_API_URL=https://tourism-rag-backend-347968285860.me-west1.run.app
BACKEND_API_KEY=your-backend-api-key-here

# GCS bucket for conversation storage
GCS_BUCKET=tarasa_tourist_bot_content

# Meta Graph API version
META_GRAPH_API_VERSION=v22.0

# ── Single-number mode (legacy / simple deployments) ──────────────────────────
# Set these for a single phone number. If PHONE_NUMBER_MAP is set, these are
# used as fallback defaults but are not required.

WHATSAPP_ACCESS_TOKEN=your-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here

# ── Multi-number mode ─────────────────────────────────────────────────────────
# Set PHONE_NUMBER_MAP to route multiple WhatsApp numbers to different areas/sites.
# Format: phone_number_id:access_token:area:site (comma-separated, no spaces)
#
# Example with two numbers:
#   PHONE_NUMBER_MAP=111111111:EAAtoken1:area1:site1,222222222:EAAtoken2:area2:site2
#
# When PHONE_NUMBER_MAP is set, WHATSAPP_ACCESS_TOKEN and WHATSAPP_PHONE_NUMBER_ID
# become optional (tokens are taken from the map).
#
PHONE_NUMBER_MAP=
